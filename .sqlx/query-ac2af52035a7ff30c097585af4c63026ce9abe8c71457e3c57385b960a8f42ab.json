  "query": "\n            INSERT INTO users (sub, email, display_name)\n            VALUES ($1, $2, $3)\n            ON CONFLICT (sub) DO UPDATE\n                SET display_name = EXCLUDED.display_name,\n                    updated_at = now()\n            RETURNING id, sub, email, display_name, is_active, created_at, updated_at\n            ",
