# Copy to `.env` for local development. `.env` is git-ignored.
OPSGATE_BIND_ADDR=0.0.0.0:9091
OPSGATE_DATABASE_URL=postgres://opsgate:opsgate@localhost:5432/opsgate
OPSGATE_DB_MAX_CONNECTIONS=10
# `json` for structured logs; anything else for human-readable.
LOG_FORMAT=
# Tracing filter, e.g. opsgate_api=debug,sqlx=warn
RUST_LOG=opsgate_api=info,opsgate_db=info,tower_http=info
# authgate OAuth/JWKS settings for login + Bearer verification.
OPSGATE_AUTHGATE_URL=https://authgate.project-jelly.io
OPSGATE_PUBLIC_URL=http://localhost:9091
OPSGATE_OAUTH_CLIENT_ID=opsgate-web
OPSGATE_OAUTH_REDIRECT_URL=http://localhost:9091/callback
OPSGATE_RESOURCE_URL=http://localhost:9091/mcp
OPSGATE_JWKS_CACHE_TTL_SECS=300

# Base64-encoded 32-byte key for sealing credential secrets. Replace in real use.
OPSGATE_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
