# Copy to `.env` for local development. `.env` is git-ignored.
BIND_ADDR=0.0.0.0:9091
DATABASE_URL=postgres://opsgate:opsgate@localhost:5432/opsgate
DB_MAX_CONNECTIONS=10
# `json` for structured logs; anything else for human-readable.
LOG_FORMAT=
# Tracing filter, e.g. opsgate_api=debug,sqlx=warn
RUST_LOG=opsgate_api=info,opsgate_db=info,tower_http=info
# authgate OAuth/JWKS settings for login + Bearer verification.
AUTHGATE_URL=https://authgate.project-jelly.io
OPSGATE_PUBLIC_URL=http://localhost:9091
OAUTH_CLIENT_ID=opsgate-web
OAUTH_REDIRECT_URL=http://localhost:9091/callback
RESOURCE_URL=http://localhost:9091/mcp
JWKS_CACHE_TTL_SECS=300
